# URL base da API backend.
# Apenas REACT_APP_API_URL é necessária. As demais opções do docker são injetadas pelo compose.
# Desenvolvimento local (sem Docker):  REACT_APP_API_URL=http://localhost:4000
# Desenvolvimento com Docker:          REACT_APP_API_URL=http://localhost:4000
# Produção (Vercel):                   REACT_APP_API_URL=https://seu-backend.vercel.app
REACT_APP_API_URL=http://localhost:4000