# ──────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente para Docker Compose – Café Gourmet
# Copie este arquivo para .env: cp .env.example .env
# Este arquivo só é utilizado para build local via docker
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=cafeteria
POSTGRES_PASSWORD=cafeteria123
POSTGRES_DB=cafeteria_db

# ── Backend ───────────────────────────────────────────────────────────────────
# ATENÇÃO: dentro do Docker, o host do banco é "db" (nome do serviço no compose)
DATABASE_URL=postgresql://cafeteria:cafeteria123@db:5432/cafeteria_db

# Segredo para assinar os JWTs de autenticação do admin
JWT_SECRET=segredo_local_docker_troque_em_producao

# Token do Vercel Blob Storage (opcional para Docker local).
# Deixe vazio para rodar sem upload de imagens.
# Para habilitar: cole o token do painel Vercel > Storage > Blob
BLOB_READ_WRITE_TOKEN=
