{
  "$schema": "https://vercel.sh",
  "version": 2,
  "functions": {
    "app.js": {
      "includeFiles": [
        "swagger.json",
        "prisma/**",
        "src/**",
        "node_modules/swagger-ui-dist/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app.js"
    }
  ]
}
