# ──────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente do Backend – Café Gourmet
# Copie este arquivo para .env: cp .env.example .env
# Este arquivo configura o servidor Node.js/Express para execução local sem Docker
# ──────────────────────────────────────────────────────────────────────────────

# Porta em que o servidor backend irá escutar
PORT=4000

# URL de conexão com o banco de dados PostgreSQL
# Substitua com as suas credenciais locais
# Exemplo: postgresql://usuario:senha@localhost:5432/cafeteria_db
DATABASE_URL=

# Segredo para assinatura e verificação dos tokens JWT de autenticação do administrador
JWT_SECRET=segredo_local_desenvolvimento_troque_em_producao

# Configuração de Armazenamento de Imagens
# - Defina como "true" para salvar arquivos localmente na pasta "back/uploads/"
# - Defina como "false" para fazer o upload diretamente para o Vercel Blob Storage
USE_LOCAL_STORAGE=true

# Token de acesso do Vercel Blob Storage (obrigatório somente se USE_LOCAL_STORAGE for "false")
# Obtenha este token no painel da Vercel (Storage > Blob)
BLOB_READ_WRITE_TOKEN=